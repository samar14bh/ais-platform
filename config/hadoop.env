# Hadoop cluster configuration consumed by apache/hadoop:3.3.6
# Both hdfs-namenode and hdfs-datanode read this file via env_file.
# Spark containers inherit HDFS_NAMENODE/HDFS_PORT separately and build
# the URI themselves (hdfs://hdfs-namenode:8020).

HADOOP_CONF_DIR=/opt/hadoop/etc/hadoop
HADOOP_LOG_DIR=/tmp/hadoop-logs

# Core site — tells every process where the NameNode RPC lives
CORE-SITE.XML_fs.default.name=hdfs://hdfs-namenode:8020
CORE-SITE.XML_fs.defaultFS=hdfs://hdfs-namenode:8020

# HDFS site — replication factor 1 for single-node dev cluster
HDFS-SITE.XML_dfs.replication=1
HDFS-SITE.XML_dfs.namenode.name.dir=file:///hadoop/dfs/name
HDFS-SITE.XML_dfs.datanode.data.dir=file:///hadoop/dfs/data
# Allow the NameNode web UI to be accessible from outside the container
HDFS-SITE.XML_dfs.namenode.http-address=0.0.0.0:9870
# Disable safemode exit threshold (single datanode — don't block on replication)
HDFS-SITE.XML_dfs.namenode.safemode.threshold-pct=0

# MapReduce / YARN (not used — included so hadoop commands don't warn)
MAPRED-SITE.XML_mapreduce.framework.name=local
YARN-SITE.XML_yarn.resourcemanager.hostname=hdfs-namenode
