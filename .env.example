# ============================================
# Core Database Credentials
# ============================================
MONGO_USER=admin
MONGO_PASSWORD=change_me
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=root_password_change_me
MINIO_USER=minioadmin
MINIO_PASSWORD=change_me
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minio_root_password_change_me

# ============================================
# AISStream Ingestion Configuration
# ============================================
AISSTREAM_API_KEY=your_aisstream_api_key
AIS_FILTER_MESSAGE_TYPES=PositionReport
AIS_BOUNDING_BOXES_JSON=[[[30.0,-6.0],[47.0,37.0]]]

# ============================================
# Service Connectivity
# ============================================
KAFKA_BROKER=kafka:9092
CASSANDRA_HOST=cassandra
CASSANDRA_PORT=9042
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================
# Backend API Configuration
# ============================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
VITE_API_BASE_URL=http://localhost:8000

# ============================================
# Stream Behavior Configuration
# ============================================
KAFKA_STARTING_OFFSETS=latest

# ============================================
# Batch Job Configuration
# ============================================
# Format: YYYY-MM-DD (Example: 2026-04-18)
BATCH_DATE=

