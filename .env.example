# Core credentials
MONGO_USER=admin
MONGO_PASSWORD=change_me
MINIO_USER=minioadmin
MINIO_PASSWORD=change_me

# AISStream ingestion
AISSTREAM_API_KEY=your_aisstream_api_key
AIS_FILTER_MESSAGE_TYPES=PositionReport
AIS_BOUNDING_BOXES_JSON=[[[30.0,-6.0],[47.0,37.0]]]

# Service connectivity overrides (optional)
KAFKA_BROKER=kafka:9092
CASSANDRA_HOST=cassandra
CASSANDRA_PORT=9042
REDIS_HOST=redis

# Stream behavior (optional)
KAFKA_STARTING_OFFSETS=latest

# Batch behavior (optional)
# Example: 2026-04-18
BATCH_DATE=
